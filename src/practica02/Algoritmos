        } while (exponente < 0);
        
        System.out.println("La potencia es " + potencia(base, exponente));
    }

    // Fibonacci 
    public static long fib(int n) {
        if (n == 0 || n == 1) return n;
        return fib(n - 1) + fib(n - 2);
    }

    public static void algoritmoFibonacci() {
        System.out.print("Introduzca un número para Fibonacci: ");
        int n = sc.nextInt();
        while (n < 0) {
            System.out.print("Introduzca un valor mayor a 0: ");
            n = sc.nextInt();
        }
        System.out.println(fib(n));
    }

    // Legendre
    public static double legen(int n, double x) {
        if (n == 0) return 1;
        if (n == 1) return x;
        return ((2.0 * n - 1.0) / n) * x * legen(n - 1, x) - ((n - 1.0) / n) * legen(n - 2, x);
    }

    public static void algoritmoLegendre() {
        System.out.print("Introduzca x y el grado n: ");
        double x = sc.nextDouble();
        int n = sc.nextInt();
        System.out.println(legen(n, x));
    }

    // Ackermann 
    public static long acker(int n, int m) {
        if (m == 0) return n + 1;
        if (n == 0) return acker(1, m - 1);
        return acker((int)acker(n - 1, m), m - 1);
    }

    public static void algoritmoAckermann() {
        System.out.print("Introduzca n y m: ");
        int n = sc.nextInt();
        int m = sc.nextInt();
        System.out.println(acker(n, m));
    }

    // Máximo Común Divisor 
    public static int mcd(int m, int n) {
        if (n <= m && (m % n) == 0) return n;
        if (m < n) return mcd(n, m);
        return mcd(n, m % n);
    }

    public static void algoritmoMaximoComunDivisor() {
        System.out.print("Introduzca dos números para MCD: ");
        int n = sc.nextInt();
        int m = sc.nextInt();
        System.out.println(mcd(m, n));
    }

    // Cambio de Base 
    public static String convertirNumero(int n) {
        if (n >= 10 && n <= 15) {
            return String.valueOf((char)('A' + (n - 10)));
        }
        return String.valueOf(n);
    }

    public static String cambiobase(int n, int base) {
        if (n < base) return convertirNumero(n);
        return cambiobase(n / base, base) + convertirNumero(n % base);
    }

    public static void algoritmoCambioDeBase() {
        System.out.print("Introduzca número y base: ");
        int n = sc.nextInt();
        int base = sc.nextInt();
        System.out.println("Base " + base + ": " + cambiobase(n, base));
        System.out.println("Hexadecimal: " + cambiobase(n, 16));
    }
}